// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields:
//   - uid: string (required, immutable)
//   - email: string (optional)
//   - phoneNumber: string (optional)
//   - numericId: number (required)
//   - username: string (required)
//   - balance: number (required, >= 0)
//   - vipLevel: number (required)
//   - inviteCode: string (required)
//   - invitedBy: string (optional)
//   - createdAt: timestamp (required)
//   - role: string (required, 'user' or 'admin')
//
// Collection: games
// Fields:
//   - periodId: string (required)
//   - gameType: string (required, '30s', '1m', '3m', '5m')
//   - startTime: timestamp (required)
//   - endTime: timestamp (required)
//   - resultNumber: number (optional, 0-9)
//   - resultColor: string (optional)
//   - resultSize: string (optional, 'Big' or 'Small')
//   - status: string (required, 'active' or 'completed')
//
// Collection: bets
// Fields:
//   - uid: string (required, immutable)
//   - periodId: string (required)
//   - gameType: string (required)
//   - selection: string (required)
//   - amount: number (required, > 0)
//   - multiplier: number (required, > 0)
//   - totalAmount: number (required)
//   - status: string (required, 'pending', 'win', 'lost')
//   - winAmount: number (optional)
//   - createdAt: timestamp (required)
//
// Collection: transactions
// Fields:
//   - uid: string (required, immutable)
//   - type: string (required, 'deposit', 'withdraw', 'bet', 'win')
//   - amount: number (required)
//   - status: string (required, 'pending', 'completed', 'failed')
//   - description: string (optional)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "triloksinghrathore51@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return (!('uid' in data) || data.uid is string) &&
             (!('balance' in data) || (data.balance is number && data.balance >= -1000000)) && // Allow some flexibility for increments
             (!('totalDeposits' in data) || data.totalDeposits is number) &&
             (!('totalBets' in data) || data.totalBets is number) &&
             (!('isDemo' in data) || data.isDemo is bool);
    }

    function isValidGame(data) {
      return data.periodId is string &&
             data.gameType in ['30s', '1m', '3m', '5m'] &&
             data.startTime is timestamp &&
             data.endTime is timestamp &&
             data.status in ['active', 'completed'] &&
             (data.createdAt == null || data.createdAt is timestamp);
    }

    function isValidBet(data) {
      return data.uid is string &&
             data.periodId is string &&
             data.gameType in ['30s', '1m', '3m', '5m'] &&
             data.selection is string &&
             data.amount is number && data.amount > 0 &&
             data.multiplier is number && data.multiplier > 0 &&
             data.totalAmount is number &&
             data.status in ['pending', 'win', 'lost'] &&
             (data.createdAt == null || data.createdAt is timestamp);
    }

    function isValidTransaction(data) {
      return data.uid is string &&
             data.type in ['deposit', 'withdraw', 'bet', 'win'] &&
             data.amount is number &&
             data.status in ['pending', 'completed', 'failed'] &&
             (data.createdAt == null || data.createdAt is timestamp);
    }

    function isValidGiftCode(data) {
      return data.code is string &&
             data.amount is number && data.amount > 0 &&
             data.isActive is bool;
    }

    function isValidGiftHistory(data) {
      return data.userId is string &&
             data.code is string &&
             data.amount is number &&
             data.timestamp is timestamp;
    }

    function isValidAnnouncement(data) {
      return data.title is string &&
             data.content is string &&
             (data.createdAt == null || data.createdAt is timestamp);
    }

    function isValidFeedback(data) {
      return data.userId is string &&
             data.content is string &&
             (data.createdAt == null || data.createdAt is timestamp) &&
             data.status in ['pending', 'resolved'];
    }

    function isValidPlatformFee(data) {
      return data.betId is string &&
             data.uid is string &&
             data.amount is number &&
             data.periodId is string &&
             data.gameType in ['30s', '1m', '3m', '5m'] &&
             (data.createdAt == null || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || (isAuthenticated() && 
                    request.query.limit <= 10 && 
                    (request.query.filters.size() == 1 && 'username' in request.query.filters));
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isOwner(userId) && request.resource.data.get('role', 'user') == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                      ((isOwner(userId) && (!('role' in request.resource.data) || !('role' in resource.data) || request.resource.data.role == resource.data.role)) || isAdmin());
    }

    match /game_rounds/{roundId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidGame(request.resource.data);
      allow update: if isAuthenticated() && 
                      (isAdmin() || (
                        request.resource.data.status == 'completed' &&
                        request.resource.data.periodId == resource.data.periodId &&
                        request.resource.data.gameType == resource.data.gameType
                      ));
      allow delete: if isAdmin();
    }

    match /game_controls/{controlId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedInPeriod']) && request.resource.data.status == 'completed'));
      allow delete: if isAdmin();
    }

    match /bets/{betId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBet(request.resource.data) && 
                      request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && ((isOwner(resource.data.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'winAmount', 'settledAt'])) || isAdmin());
    }

    match /platform_fees/{feeId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidPlatformFee(request.resource.data);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && 
                      request.resource.data.uid == request.auth.uid &&
                      (request.resource.data.type != 'withdraw' || (
                        request.resource.data.amount >= 110 &&
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('totalBets', 0) >= get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('totalDeposits', 0)
                      ));
      allow update: if isAdmin();
    }

    match /giftCodes/{codeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidGiftCode(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentUses', 'usedBy']));
      allow delete: if isAdmin();
    }

    match /giftHistory/{historyId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidGiftHistory(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid;
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /metadata/counters {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
