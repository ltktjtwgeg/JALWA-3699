rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /_health_/{id} { allow read, write: if true; }
    match /users/{id} { allow read, write: if true; }
    match /games/{id} { allow read, write: if true; }
    match /bets/{id} { allow read, write: if true; }
    match /transactions/{id} { allow read, write: if true; }
    match /{document=**} {
      allow read, write: if true; 
    }
  }
}
