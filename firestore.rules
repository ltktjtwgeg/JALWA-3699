// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields:
//   - uid: string (required, immutable)
//   - phoneNumber: string (required)
//   - username: string (optional)
//   - balance: number (required, >= 0)
//   - vipLevel: number (optional)
//   - inviteCode: string (optional)
//   - invitedBy: string (optional)
//   - createdAt: timestamp (required)
//   - role: string (required, 'user' or 'admin')
//
// Collection: games
// Fields:
//   - periodId: string (required)
//   - gameType: string (required, '30s', '1m', '3m', '5m')
//   - startTime: timestamp (required)
//   - endTime: timestamp (required)
//   - resultNumber: number (optional, 0-9)
//   - resultColor: string (optional)
//   - resultSize: string (optional, 'Big' or 'Small')
//   - status: string (required, 'active' or 'completed')
//
// Collection: bets
// Fields:
//   - uid: string (required, immutable)
//   - periodId: string (required)
//   - gameType: string (required)
//   - selection: string (required)
//   - amount: number (required, > 0)
//   - multiplier: number (required, > 0)
//   - totalAmount: number (required)
//   - status: string (required, 'pending', 'win', 'lost')
//   - winAmount: number (optional)
//   - createdAt: timestamp (required)
//
// Collection: transactions
// Fields:
//   - uid: string (required, immutable)
//   - type: string (required, 'deposit', 'withdraw', 'bet', 'win')
//   - amount: number (required)
//   - status: string (required, 'pending', 'completed', 'failed')
//   - description: string (optional)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "triloksinghrathore51@gmail.com");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.phoneNumber is string &&
             data.username is string &&
             data.balance is number && data.balance >= 0 &&
             data.vipLevel is number &&
             data.inviteCode is string &&
             (data.invitedBy == null || data.invitedBy is string) &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidGame(data) {
      return data.periodId is string &&
             data.gameType in ['30s', '1m', '3m', '5m'] &&
             data.startTime is timestamp &&
             data.endTime is timestamp &&
             data.status in ['active', 'completed'] &&
             (data.resultNumber == null || data.resultNumber is number) &&
             (data.createdAt == null || data.createdAt is timestamp);
    }

    function isValidBet(data) {
      return data.uid is string &&
             data.periodId is string &&
             data.gameType is string &&
             data.selection is string &&
             data.amount is number && data.amount > 0 &&
             data.multiplier is number && data.multiplier > 0 &&
             data.totalAmount is number &&
             data.status in ['pending', 'win', 'lost'] &&
             data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.uid is string &&
             data.type in ['deposit', 'withdraw', 'bet', 'win'] &&
             data.amount is number &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                      ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidGame(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resultNumber', 'resultColor', 'resultSize']) && request.resource.data.status == 'completed');
      allow delete: if isAdmin();
    }

    match /game_controls/{controlId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedInPeriod']) && request.resource.data.status == 'completed');
      allow delete: if isAdmin();
    }

    match /bets/{betId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBet(request.resource.data) && 
                      request.resource.data.uid == request.auth.uid;
      allow update: if (isOwner(resource.data.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'winAmount'])) || isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && 
                      request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() && isValidTransaction(request.resource.data);
    }
  }
}
