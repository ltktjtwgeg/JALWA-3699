{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and wallet information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "numericId": { "type": "number" },
        "email": { "type": ["string", "null"] },
        "phoneNumber": { "type": ["string", "null"] },
        "username": { "type": "string" },
        "balance": { "type": "number" },
        "totalDeposits": { "type": "number" },
        "totalBets": { "type": "number" },
        "vipLevel": { "type": "number" },
        "inviteCode": { "type": "string" },
        "invitedBy": { "type": ["string", "null"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isDemo": { "type": "boolean" }
      },
      "required": ["uid", "balance", "role"]
    },
    "Game": {
      "title": "Game",
      "description": "A single round of the color prediction game",
      "type": "object",
      "properties": {
        "periodId": { "type": "string" },
        "gameType": { "type": "string", "enum": ["30s", "1m", "3m", "5m"] },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "resultNumber": { "type": "number" },
        "resultColor": { "type": "string" },
        "resultSize": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["periodId", "gameType", "startTime", "endTime", "status"]
    },
    "Bet": {
      "title": "Bet",
      "description": "A bet placed by a user on a game round",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "periodId": { "type": "string" },
        "gameType": { "type": "string" },
        "selection": { "type": "string" },
        "amount": { "type": "number" },
        "multiplier": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "won", "lost"] },
        "winAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "periodId", "gameType", "selection", "amount", "multiplier", "totalAmount", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction records",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "bet", "win"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "type", "amount", "status", "createdAt"]
    },
    "GameControl": {
      "title": "GameControl",
      "description": "Admin controls for forcing game results",
      "type": "object",
      "properties": {
        "gameType": { "type": "string", "enum": ["30s", "1m", "3m", "5m"] },
        "targetNumber": { "type": "number" },
        "targetSize": { "type": "string", "enum": ["Big", "Small"] },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "usedInPeriod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["gameType", "status", "createdAt"]
    },
    "GiftCode": {
      "title": "GiftCode",
      "description": "Redeemable gift codes generated by admin",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "amount": { "type": "number" },
        "isActive": { "type": "boolean" },
        "maxUses": { "type": "number" },
        "currentUses": { "type": "number" },
        "usedBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["code", "amount", "isActive"]
    },
    "GiftHistory": {
      "title": "GiftHistory",
      "description": "Records of gift code redemptions by users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "code": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "code", "amount", "timestamp"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "System announcements for users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and suggestions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "resolved"] }
      },
      "required": ["userId", "content", "createdAt", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Game rounds"
    },
    "/bets/{betId}": {
      "schema": "Bet",
      "description": "User bets"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions"
    },
    "/game_controls/{controlId}": {
      "schema": "GameControl",
      "description": "Admin game controls"
    },
    "/giftCodes/{codeId}": {
      "schema": "GiftCode",
      "description": "Admin generated gift codes"
    },
    "/giftHistory/{historyId}": {
      "schema": "GiftHistory",
      "description": "User redemption history"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "System announcements"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback"
    }
  }
}
